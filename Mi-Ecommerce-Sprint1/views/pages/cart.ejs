<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Mi Carrito - MiEcommerce</title>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
        <link rel="stylesheet" href="/CSS/cart.css">
        <link rel="stylesheet" href="/CSS/header.css">
        <link rel="stylesheet" href="/CSS/footer.css">
    </head>
    <body>
        <!--ENCABEZADO CON LOGO Y BUSCADOR-->
        <%- include('../partials/header') %>

        <section class="cart-nav"> <!--Agrupa los elementos de la parte de arriba.-->
                <a href="/" class="link-volver"><i class="fas fa-chevron-left"></i>Volver a Inicio</a>
                <h2>Productos en tu Carrito</h2>
        </section>

        <!--LISTA DE PRODUCTOS AGREGADOS AL CARRO-->
        <main class="cart-container">
            <% if (cart.length > 0) { %>
            <div class="cart-items">
                 <% cart.forEach(item => { %>
                    <div class="cart-item">
                            <img src="<%= item.image %>" alt="<%= item.name %>">
                        <div class="item-details">
                            <h3><%= item.name %></h3>
                            <p>Precio: <%= item.price %> puntos</p>
                            <form action="/cart/update/<%= item.id %>/decrease" method="POST" style="display:inline;">
                                <button type="submit">-</button>
                            </form>
                            <span><%= item.quantity %></span>
                            <form action="/cart/update/<%= item.id %>/increase" method="POST" style="display:inline;">
                                <button type="submit">+</button>
                            </form>
                        </div>
                            <p class="subtotal">Subtotal: <%= item.subtotal %></p>
                    </div>
            <% }) %>
            </div>

            <div class="cart-footer">
                <p>Total general: <strong><%= total %> puntos</strong></p>
                <a href="/cart/checkout" class="btn-primary">Finalizar Compra</a>
            
                <form action="/cart/clear" method="POST">
                    <button type="submit" class="btn-vaciar">Vaciar Carrito</button>
                </form>
            </div>

            <% } else { %>
                <div class="cart-empty">
                    <p>¡Tu carrito está vacío! Explora nuestros productos para empezar.</p>
                    <a href="/" class="btn-primary">Volver a la tienda</a>
                </div>
            <% } %>
        </main>
            <!--TOTAL A PAGAR Y BOTÓN DE PAGAR-->
           <section class="cart-footer">
            <p>Total de Puntos: <strong><%= total %></strong></p>
            <a href="/cart/checkout" class="btn-primary">Ir a Pagar</a>
           </section>

            
            <!--FOOTER-->
        <%- include('../partials/footer') %>

    </body>
</html>