<%- include('./header') %>
<link rel="stylesheet" href="/css/cart.css">
<link rel="stylesheet" href="/css/product.css">

<main class="contenedor-detalle">
    <nav class="breadcrumb">
        <a href="/">Volver al listado</a> | <span><%= product.category %></span>
    </nav>

    <section class="producto-principal">
        <div class="galeria-fotos">
            <div class="miniaturas">
                <img src="/Imagenes-productos/<%= product.image %>" alt="v1">
                <img src="/Imagenes-productos/<%= product.image2 || product.image %>" alt="v2">
                <img src="/Imagenes-productos/<%= product.image3 || product.image %>" alt="v3">
            </div>
            <div class="foto-grande">
                <img src="/Imagenes-productos/<%= product.image %>" alt="<%= product.name %>">
            </div>
        </div>
             
        <div class="info-compra">
            <h1><%= product.name %></h1>
            <div class="precio-puntos">
                <span class="monto"><%= product.price %></span>
                <span class="label-puntos">PUNTOS</span>
            </div>
            
            <button class="btn-agregar">Agregar al Carrito</button>

            <div class="texto-descripcion">
                <p><%= product.description %></p>
            </div>
        </div>
    </section>

    <section class="relacionados">
        <h3>También te puede interesar</h3>
        <div class="grilla-productos">
            
            <% relatedProducts.forEach(similar => { %>
                <article class="tarjeta-chica">
                    <a href="/products/<%= similar.id %>" style="text-decoration: none; color: inherit;">
                        <img src="/Imagenes-productos/<%= similar.image %>" alt="<%= similar.name %>">
                        <div class="cuerpo-tarjeta">
                            <p class="nombre-relacionado"><%= similar.name %></p>
                            <div class="precio-relacionado">
                                <span class="puntos"><%= similar.price %></span>
                                <span class="label">PUNTOS</span>
                            </div>
                        </div>
                    </a>
                </article>
            <% }); %>

            <% if (relatedProducts.length == 0) { %>
                <p>No hay productos relacionados disponibles.</p>
            <% } %>

        </div>
    </section>

    <section class="barra-categorias-oscura">
        <div class="item-cat"><img src="/imagenes-index/electronica.png"><span>Electrónica</span></div>
        <div class="item-cat"><img src="/imagenes-index/alimentos.png"><span>Alimentos</span></div>
        <div class="item-cat"><img src="/imagenes-index/bebidas.png"><span>Bebidas</span></div>
        <div class="item-cat"><img src="/imagenes-index/indumentaria.png"><span>Indumentaria</span></div>
        <div class="item-cat"><img src="/imagenes-index/juegos.png"><span>Juegos</span></div>
        <div class="item-cat"><img src="/imagenes-index/automotor.png"><span>Automotor</span></div>
        <div class="item-cat"><img src="/imagenes-index/hogar.png"><span>Hogar</span></div>
        <div class="item-cat"><img src="/imagenes-index/otros.png"><span>Otros</span></div>
    </section>
</main>

<%- include('./footer') %>
